{
  "constantRoutes": [
    {
      "path": "/entity",
      "component": "@/layouts",
      "children": [
        {
          "path": "",
          "component": "@/pages/entity/index.vue",
          "name": "Entity",
          "meta": {
            "title": "实体管理",
            "elIcon": "Management"
          }
        }
      ]
    }
  ],
  "dynamicRoutes": [
    {
      "path": "/entity",
      "component": "@/layouts",
      "redirect": "/entity/list",
      "name": "Entity",
      "meta": {
        "title": "实体管理",
        "elIcon": "Management",
        "roles": ["admin", "editor"],
        "alwaysShow": true
      },
      "children": [
        {
          "path": "list",
          "component": "@/pages/entity/index.vue",
          "name": "EntityList",
          "meta": {
            "title": "实体列表",
            "roles": ["admin"]
          }
        }
      ]
    }
  ]
}
